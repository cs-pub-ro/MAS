# Copy this file to ".env" and fill in your real key.
# .env is read automatically by llm_client.py via python-dotenv at import time.

# REQUIRED: your OpenAI API key.
OPENAI_API_KEY=sk-replace-me

# OPTIONAL: default model used by every agent function.
# Examples: gpt-4o-mini (cheap, fast), gpt-4o, gpt-4.1, gpt-4.1-mini, o4-mini
OPENAI_MODEL=gpt-4o-mini

# OPTIONAL: sampling controls.
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# To see the full rendered prompts in the log, raise the `llm` logger level
# to DEBUG in logging_conf.yaml.
